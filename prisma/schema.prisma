datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  email       String       @unique
  password    String?
  name        String?
  image       String?
  googleId    String?      @unique
  role        String?      @default("USER")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  savedPlaces SavedPlace[]
  userAlerts  UserAlert[]
  trips       Trip[]
}

model SavedPlace {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId 
  name      String
  lat       Float
  lng       Float
  distance  String?
  intensity String?
  duration  Int?
  createdAt DateTime @default(now())
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  role      String   @default("super-admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActiveHazard {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String?
  description String?
  lat         Float
  lng         Float
  severity    String?
  createdAt   DateTime @default(now())
}

model HazardHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String?
  description String?
  lat         Float
  lng         Float
  severity    String?
  source      String?
  signature   String?
  observedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}

model PermanentHazard {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String?
  description String?
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())
}

model UserAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String?
  lat         Float
  lng         Float
  createdAt   DateTime @default(now())
  userId      String?  @db.ObjectId
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  date                   DateTime @default(now())
  destinationName        String
  durationMs             Int
  alertsTriggeredCount   Int
  responseTimes          Float[]
  unsafeZonesEncountered String[]
  userId                 String   @db.ObjectId
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
